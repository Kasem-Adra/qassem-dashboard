{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@qassem/ui": [
        "packages/ui/src"
      ],
      "@qassem/theme-engine": [
        "packages/theme-engine/src"
      ],
      "@qassem/ai-core": [
        "packages/ai-core/src"
      ],
      "@qassem/agents-core": [
        "packages/agents-core/src"
      ],
      "@qassem/runtime-core": [
        "packages/runtime-core/src"
      ],
      "@qassem/realtime": [
        "packages/realtime/src"
      ],
      "@qassem/database": [
        "packages/database/src"
      ],
      "@qassem/security": [
        "packages/security/src"
      ],
      "@qassem/abos-core": [
        "packages/abos-core/src"
      ]
    }
  }
}
